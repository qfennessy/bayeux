# Generated outputs
*.jpg
*.jpeg
*.png
*.mp4
*.webm
*.webp
out/
output/
cache/

# Hero / doc images are curated and tracked even though images are
# otherwise gitignored.
!docs/
!docs/images/
!docs/images/*.jpg
!docs/images/*.jpeg
!docs/images/*.png
!assets/
!assets/*.jpg
!assets/*.jpeg
!assets/*.png

# Built gallery for Vercel — the index.html and copied tapestry JPGs
# need to be tracked so `vercel --prod` can deploy them reproducibly
# from a git push.
!public/
!public/**/*.html
!public/**/*.jpg
!public/**/*.jpeg
!public/**/*.png
!public/**/*.svg
!public/**/*.ico
!public/**/*.webmanifest

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.venv/
venv/
.python-version

# Node
node_modules/

# Environment
.env
.env.local

# IDE / OS
.vscode/
.idea/
.DS_Store

# Nunchaku starter-kit leftovers — kept on disk as local reference but
# not tracked in this repo since it's now a tapestry project, not a
# Nunchaku demo. Tapestry-relevant examples (text_to_image.py,
# image_to_image.py) are explicitly re-included below.
demo/
tests/
pytest.ini
examples/curl/
examples/javascript/
examples/python/
!examples/python/text_to_image.py
!examples/python/image_to_image.py
.vercel
